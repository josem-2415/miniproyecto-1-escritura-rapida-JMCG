<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="500.0" prefWidth="600.0" style="-fx-background-color: #120500;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.escriturarapida.controller.FinalController">

   <VBox alignment="CENTER" spacing="25" style="-fx-background-color: #260a00; -fx-border-color: #8b2100; -fx-border-width: 4; -fx-border-radius: 24; -fx-background-radius: 24; -fx-padding: 40;">

      <effect>
         <DropShadow color="#00000080" offsetY="15" radius="30" spread="0.1" />
      </effect>

      <VBox alignment="CENTER" spacing="10">
         <Label style="-fx-text-fill: #ff3c00; -fx-font-size: 38px; -fx-font-weight: 900; -fx-font-family: 'System';" text="¡JUEGO TERMINADO!">
            <effect>
               <DropShadow blurType="GAUSSIAN" color="#ff3c0099" radius="15" spread="0.5" />
            </effect>
         </Label>

         <Region maxHeight="4" maxWidth="90" minHeight="4" style="-fx-background-color: #ff3c00; -fx-background-radius: 2;" />
      </VBox>

      <VBox prefHeight="500.0" prefWidth="600.0" spacing="20" style="-fx-padding: 10 0 20 0;">

         <VBox alignment="CENTER" style="-fx-background-color: rgba(0,0,0,0.3); -fx-border-color: #3d1400; -fx-border-width: 2; -fx-background-radius: 16; -fx-border-radius: 16; -fx-padding: 25;">
            <Label style="-fx-text-fill: #ffb566; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;" text="CALIFICACIÓN" />
            <Label style="-fx-text-fill: white; -fx-font-size: 54px; -fx-font-weight: 900;" text="¡EXCELENTE!" />
         </VBox>

         <HBox alignment="CENTER" spacing="15">
            <VBox alignment="CENTER" maxWidth="Infinity" style="-fx-background-color: rgba(0,0,0,0.2); -fx-border-color: rgba(139,33,0,0.3); -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 15;" HBox.hgrow="ALWAYS">
               <Label style="-fx-text-fill: #ff3c00; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;" text="RACHA" />
               <Label fx:id="streakLabel" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="42" />
            </VBox>
         </HBox>
      </VBox>

      <VBox alignment="CENTER" spacing="15" style="-fx-padding: 0 0 10 0;">
         <Button fx:id="btnPlayAgain" maxWidth="Infinity" style="-fx-background-color: #ff3c00; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 900; -fx-padding: 15; -fx-background-radius: 16; -fx-cursor: hand;" text="VOLVER A JUGAR" />

         <Button fx:id="btnMainMenu" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: rgba(139,33,0,0.5); -fx-border-width: 2; -fx-text-fill: rgba(255, 200, 170, 0.8); -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 16; -fx-border-radius: 16; -fx-cursor: hand;" text="REGRESAR AL MENÚ" />
      </VBox>
   </VBox>
</StackPane>
